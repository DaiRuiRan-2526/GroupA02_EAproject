{% extends "base.html,j2" %}

{% block content %}

<!-- Hero Section -->
<section class="bg-dark text-white py-5">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="display-3 fw-bold mb-4">
          ASP.NET Core
        </h1>
        <p class="lead fs-3 mb-5">
          建置現代、雲端就緒、高效能的 Web 應用程式與服務<br>
          使用 C# 與 .NET 開發
        </p>
        
    

        <div class="mt-5 text-muted small">
          免費 · 開源 · 跨平台 · 高性能
        </div>
      </div>

      <!-- 右側圖片 -->
      <div class="col-lg-6 d-none d-lg-block text-center">
        <img src="https://picsum.photos/id/1015/720/480" 
             alt="ASP.NET Core" 
             class="img-fluid rounded-4 shadow-lg">
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold">為什麼選擇 ASP.NET Core？</h2>
    </div>

    <div class="row g-4">
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
          <div class="card-body">
            <i class="bi bi-speedometer2 text-primary fs-1 mb-4"></i>
            <h4 class="fw-bold">高性能</h4>
            <p class="text-muted">業界領先的執行速度與低記憶體使用</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
          <div class="card-body">
            <i class="bi bi-cloud-fill text-primary fs-1 mb-4"></i>
            <h4 class="fw-bold">雲端原生</h4>
            <p class="text-muted">完美支援 Docker、Kubernetes 與各大雲平台</p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm text-center p-4">
          <div class="card-body">
            <i class="bi bi-shield-check-fill text-primary fs-1 mb-4"></i>
            <h4 class="fw-bold">企業級安全</h4>
            <p class="text-muted">內建身份驗證、授權與安全性功能</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Modern Development Section -->
<section class="py-5 bg-white">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h2 class="display-6 fw-bold mb-4">使用 C# 建置現代 Web 應用</h2>
        <ul class="list-unstyled fs-5">
          <li class="mb-4"><i class="bi bi-check-circle-fill text-success me-3"></i>Blazor – 使用 C# 建置互動式 Web UI</li>
          <li class="mb-4"><i class="bi bi-check-circle-fill text-success me-3"></i>Minimal APIs – 極簡風格的 Web API</li>
          <li class="mb-4"><i class="bi bi-check-circle-fill text-success me-3"></i>MVC 與 Razor Pages – 成熟的 Web 開發框架</li>
          <li class="mb-4"><i class="bi bi-check-circle-fill text-success me-3"></i>Entity Framework Core – 強大的 ORM</li>
        </ul>
      </div>
      <div class="col-lg-6 text-center">
        <img src="https://picsum.photos/id/201/700/420" 
             alt="ASP.NET Core Development" 
             class="img-fluid rounded-4 shadow">
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="py-5 bg-dark text-white text-center">
  <div class="container py-5">
    <h2 class="display-5 fw-bold mb-4">開始使用 ASP.NET Core</h2>
    <p class="lead mb-5">從今天開始，建置你的下一個偉大應用程式</p>
    
  </div>
</section>

{% endblock %}