<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ASP.NET Core - Free. Cross-platform. Open-source{% endblock %}</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            padding-top: 70px;
            background-color: #f8f9fa;
        }
        .navbar-dark.bg-dark {
            background-color: #1e1e1e !important;
        }
        .navbar-brand {
            font-weight: 700;
            font-size: 1.6rem;
        }
        .navbar-brand i {
            color: #5c2d91;
        }
        .btn-purple {
            background-color: #5c2d91;
            border-color: #5c2d91;
            color: white;
        }
        .btn-purple:hover {
            background-color: #4a2373;
            border-color: #4a2373;
            color: white;
        }
        .btn-outline-purple {
            border-color: #5c2d91;
            color: #5c2d91;
        }
        .btn-outline-purple:hover {
            background-color: #5c2d91;
            color: white;
        }
        .hero {
            background: linear-gradient(135deg, #5c2d91 0%, #7b4cb6 100%);
            color: white;
            padding: 5rem 0;
            margin-bottom: 3rem;
            border-radius: 0 0 2rem 2rem;
        }
        .hero h1 {
            font-weight: 700;
            font-size: 3.5rem;
        }
        .card {
            border: none;
            border-radius: 1rem;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card i {
            font-size: 2.5rem;
            color: #5c2d91;
        }
        footer {
            background-color: #1e1e1e;
            color: #ccc;
            padding: 3rem 0;
            margin-top: 4rem;
        }
        footer a {
            color: #aaa;
            text-decoration: none;
        }
        footer a:hover {
            color: white;
        }
        .bg-purple {
            background-color: #5c2d91;
        }
        .text-purple {
            color: #5c2d91;
        }
        .hover-shadow {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .hover-shadow:hover {
            transform: translateY(-4px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
        }
        .tutorial-content h2 {
            font-size: 1.8rem;
            margin-top: 2rem;
            margin-bottom: 1rem;
        }
        .tutorial-content pre {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 1rem;
            border-radius: 0.5rem;
            overflow-x: auto;
        }

    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="{{ url_for('main.index') }}">
                <i class="fab fa-microsoft"></i> ASP.NET Core
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ url_for('tutorials.list') }}">Tutorials</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ url_for('resources.list') }}">Resources</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ url_for('community.index') }}">Community</a></li>
                    {% if current_user.is_authenticated and current_user.is_admin() %}
                    <li class="nav-item"><a class="nav-link" href="{{ url_for('admin.dashboard') }}">Admin</a></li>
                    {% endif %}
                </ul>
                <ul class="navbar-nav">
                    {% if current_user.is_authenticated %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i> {{ current_user.username }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="{{ url_for('main.user_profile', username=current_user.username) }}">Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ url_for('auth.logout') }}">Logout</a></li>
                                <li><a class="dropdown-item" href="{{ url_for('tutorials.list_categories') }}">Manage Categories</a></li>
                                <li><a class="dropdown-item" href="{{ url_for('tutorials.list_tags') }}">Manage Tags</a></li>
                                <li><a class="dropdown-item" href="{{ url_for('tutorials.create') }}">New Tutorial</a></li>
                            </ul>
                        </li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link" href="{{ url_for('auth.login') }}">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ url_for('auth.register') }}">Register</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="container mt-3">
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                    <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endif %}
        {% endwith %}
    </div>

    <!-- Main Content -->
    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5>ASP.NET Core</h5>
                    <p class="text-muted">Free. Cross-platform. Open-source.<br>Build web apps and services with .NET and C#.</p>
                </div>
                <div class="col-md-2 mb-3">
                    <h6>Learn</h6>
                    <ul class="list-unstyled">
                        <li><a href="{{ url_for('tutorials.list') }}">Tutorials</a></li>
                        <li><a href="#">Documentation</a></li>
                        <li><a href="#">Samples</a></li>
                    </ul>
                </div>
                <div class="col-md-2 mb-3">
                    <h6>Community</h6>
                    <ul class="list-unstyled">
                        <li><a href="{{ url_for('community.index') }}">Forum</a></li>
                        <li><a href="#">GitHub</a></li>
                        <li><a href="#">Stack Overflow</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Follow Us</h6>
                    <a href="#" class="text-muted me-3"><i class="fab fa-twitter fa-lg"></i></a>
                    <a href="#" class="text-muted me-3"><i class="fab fa-github fa-lg"></i></a>
                    <a href="#" class="text-muted"><i class="fab fa-linkedin fa-lg"></i></a>
                </div>
            </div>
            <hr>
            <div class="text-center text-muted small">
                &copy; 2026 ASP.NET Core Community | Rebuilt with Flask
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    {% block extra_js %}{% endblock %}
</body>
</html>