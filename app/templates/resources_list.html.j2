{% extends "base.html.j2" %}

{% block title %}Resources - ASP.NET Core{% endblock %}

{% block content %}
<div class="container my-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5><i class="fas fa-filter me-2"></i>Filter by Type</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="{{ url_for('resources.list') }}" class="list-group-item list-group-item-action">All</a>
                    <a href="{{ url_for('resources.list', type='ebook') }}" class="list-group-item list-group-item-action">E-books</a>
                    <a href="{{ url_for('resources.list', type='video') }}" class="list-group-item list-group-item-action">Videos</a>
                    <a href="{{ url_for('resources.list', type='sample') }}" class="list-group-item list-group-item-action">Sample Code</a>
                    <a href="{{ url_for('resources.list', type='tool') }}" class="list-group-item list-group-item-action">Tools</a>
                </div>
            </div>
            <div class="card shadow-sm border-0 rounded-4 mt-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5><i class="fas fa-tags me-2"></i>Categories</h5>
                </div>
                <div class="list-group list-group-flush">
                    {% for cat in categories %}
                    <a href="{{ url_for('resources.list', category=cat.slug) }}" class="list-group-item list-group-item-action">{{ cat.name }}</a>
                    {% endfor %}
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <h2 class="mb-4">Resources</h2>
            <div class="row g-4">
                {% for resource in resources %}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4">
                        <div class="card-body">
                            <span class="badge bg-info mb-2">{{ resource.type|capitalize }}</span>
                            <h5 class="card-title"><a href="{{ url_for('resources.view', id=resource.id) }}" class="text-decoration-none text-dark">{{ resource.title }}</a></h5>
                            <p class="card-text text-muted small">{{ resource.description|truncate(80) }}</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <small><i class="fas fa-download"></i> {{ resource.download_count }} downloads</small>
                                <a href="{{ url_for('resources.download', id=resource.id) }}" class="btn btn-sm btn-purple">Download</a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}