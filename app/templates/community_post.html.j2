{% extends "base.html.j2" %}

{% block title %}{{ post.title }} - ASP.NET Core Community{% endblock %}

{% block content %}
<div class="container my-5">

    <div class="mb-4">
        <a href="{{ url_for('community.index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Community
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">

            <!-- Post content -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-5">
                    
                    {% if post.is_pinned %}
                    <span class="badge bg-warning mb-3">📌 Pinned Post</span>
                    {% endif %}

                    <!-- Post Title + Action Buttons -->
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h1 class="display-6 fw-bold mb-0">{{ post.title }}</h1>
                        
                        <!-- Admin Only: Edit & Delete Post -->
                        {% if current_user.is_authenticated and current_user.is_admin() %}
                        <div class="btn-group">
                            <a href="{{ url_for('community.edit_post', id=post.id) }}" 
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <button onclick="confirmDeletePost({{ post.id }})" 
                                    class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash me-1"></i>Delete
                            </button>
                        </div>
                        {% endif %}
                    </div>

                    <!-- Edited Tag -->
                    {% if post.is_edited %}
                    <div class="d-flex align-items-center small text-muted mb-3">
                        <i class="fas fa-edit me-1 text-primary"></i>
                        <span>Edited on {{ post.updated_at.strftime('%Y-%m-%d %H:%M') }}</span>
                    </div>
                    {% endif %}
                    
                    <!-- Author Info -->
                    <div class="d-flex align-items-center text-muted mb-4">
                        <img src="https://ui-avatars.com/api/?name={{ post.author.username if post.author else 'User' }}&background=5c2d91&color=fff" 
                             class="rounded-circle me-3" width="40" height="40" alt="">
                        <div>
                            <strong>{{ post.author.username if post.author else 'Unknown User' }}</strong>
                            <div class="small">
                                Posted on {{ post.created_at.strftime('%Y-%m-%d %H:%M') }}
                            </div>
                        </div>
                        <div class="ms-auto">
                            <span class="badge bg-light text-dark">{{ post.category }}</span>
                        </div>
                    </div>

                    <div class="post-content fs-5 lh-lg">
                        {{ post.content | safe }}
                    </div>

                    <!-- Like & Stats -->
                    <div class="d-flex gap-3 mt-4">
                        <button id="like-btn" 
                                class="btn like-button {{ 'btn-danger text-white' if current_user_has_liked else 'btn-outline-danger' }}"
                                onclick="toggleLike({{ post.id }})">
                            <i class="fas fa-heart" id="like-icon" 
                               style="{{ 'color: white;' if current_user_has_liked else 'color: #dc3545;' }}"></i> 
                            <span id="like-count" class="ms-1 fw-bold">{{ post.likes.count() if post.likes else 0 }}</span>
                        </button>

                        <button class="btn btn-outline-secondary">
                            <i class="fas fa-comment"></i> 
                            {{ post.reply_count }} Replies
                        </button>

                        <button class="btn btn-outline-secondary">
                            <i class="fas fa-eye"></i> 
                            {{ post.view_count }} Views
                        </button>
                    </div>
                </div>
            </div>

            <!-- Comments section -->
            <h4 class="mb-4">
                Comments ({{ comments|selectattr('parent_id', 'none')|list|length }})
            </h4>

            {% for comment in comments %}
                {% if not comment.parent_id %}   <!-- Main comments only -->

                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex">
                            <img src="https://ui-avatars.com/api/?name={{ comment.user.username if comment.user else 'User' }}&background=5c2d91&color=fff" 
                                 class="rounded-circle me-3" width="42" height="42">
                            
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong>{{ comment.user.username if comment.user else 'Unknown User' }}</strong>
                                    
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="text-muted">{{ comment.created_at.strftime('%Y-%m-%d %H:%M') }}</small>
                                        
                                        <!-- Admin Delete Button for Main Comment -->
                                        {% if current_user.is_admin() %}
                                        <button onclick="confirmDeleteComment({{ comment.id }})" 
                                                class="btn btn-sm btn-outline-danger py-0 px-2" 
                                                title="Delete Comment">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        {% endif %}
                                    </div>
                                </div>

                                <!-- Main Comment Content -->
                                <div class="mt-3">
                                    {% if comment.content == "[Comment was deleted by admin]" %}
                                        <div class="text-muted fst-italic">
                                            <i class="fas fa-info-circle me-1"></i>
                                            Comment was deleted by admin
                                        </div>
                                    {% else %}
                                        <div class="lh-base">{{ comment.content | safe }}</div>
                                    {% endif %}
                                </div>

                                <!-- Reply Button -->
                                {% if current_user.is_authenticated and comment.content != "[Comment was deleted by admin]" %}
                                <div class="mt-3">
                                    <button class="btn btn-sm btn-outline-secondary" 
                                            onclick="showReplyForm({{ comment.id }})">
                                        <i class="fas fa-reply me-1"></i>Reply
                                    </button>
                                </div>
                                {% endif %}

                                <!-- Replies Section -->
                                <div id="replies-container-{{ comment.id }}" class="mt-4">
                                    {% set replies = comment.replies.all() %}
                                    {% if replies %}
                                    <div class="small text-muted mb-2">
                                        <span onclick="toggleReplies({{ comment.id }})" style="cursor:pointer;">
                                            <i class="fas fa-chevron-down"></i> {{ replies|length }} 則回覆
                                        </span>
                                    </div>
                                    <div id="reply-list-{{ comment.id }}" class="reply-list">
                                        {% for reply in replies %}
                                        <div class="mb-3 ms-4 border-start border-2 border-purple ps-3">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <strong>{{ reply.user.username if reply.user else 'Unknown User' }}</strong>
                                                
                                                <div class="d-flex align-items-center gap-2">
                                                    <small class="text-muted">{{ reply.created_at.strftime('%Y-%m-%d %H:%M') }}</small>
                                                    
                                                    <!-- Admin Delete Button for Reply -->
                                                    {% if current_user.is_admin() %}
                                                    <button onclick="confirmDeleteReply({{ reply.id }})" 
                                                            class="btn btn-sm btn-outline-danger py-0 px-2" 
                                                            title="Delete Reply">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                    {% endif %}
                                                </div>
                                            </div>

                                            <!-- Reply Content -->
                                            <div class="mt-1">
                                                {% if reply.content == "[Comment was deleted by admin]" %}
                                                    <div class="text-muted fst-italic">
                                                        <i class="fas fa-info-circle me-1"></i>
                                                        Comment was deleted by admin
                                                    </div>
                                                {% else %}
                                                    <div>{{ reply.content | safe }}</div>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% endfor %}
                                    </div>
                                    {% endif %}
                                </div>

                                <!-- Reply Form -->
                                <div id="reply-form-{{ comment.id }}" class="reply-form mt-3" style="display: none;">
                                    <form method="POST" action="{{ url_for('community.reply_to_comment', comment_id=comment.id) }}">
                                        {{ form.hidden_tag() }}
                                        <textarea name="content" class="form-control" rows="3" placeholder="Write your reply..."></textarea>
                                        <div class="mt-2">
                                            <button type="submit" class="btn btn-purple btn-sm">Post Reply</button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm ms-2" 
                                                    onclick="hideReplyForm({{ comment.id }})">Cancel</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {% endif %}
            {% endfor %}

            <!-- Main Comment Form -->
            {% if current_user.is_authenticated %}
            <div class="card shadow-sm border-0 rounded-4 mt-5">
                <div class="card-body p-4">
                    <h5 class="mb-3">Write a Comment</h5>
                    <form method="POST" action="{{ url_for('community.create_comment', post_id=post.id) }}">
                        {{ form.hidden_tag() }}
                        {{ form.content(class="form-control", rows="5", placeholder="Share your thoughts...") }}
                        {% for error in form.content.errors %}
                            <div class="text-danger small mt-1">{{ error }}</div>
                        {% endfor %}
                        <button type="submit" class="btn btn-purple mt-3">
                            <i class="fas fa-paper-plane me-2"></i>Post Comment
                        </button>
                    </form>
                </div>
            </div>
            {% else %}
            <div class="alert alert-info mt-4">
                Please <a href="{{ url_for('auth.login') }}">login</a> to reply.
            </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
function toggleLike(postId) {
    const btn = document.getElementById('like-btn');
    const countSpan = document.getElementById('like-count');
    const icon = document.getElementById('like-icon');

    fetch(`/community/post/${postId}/like`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        countSpan.textContent = data.like_count;
        if (data.liked) {
            btn.classList.remove('btn-outline-danger');
            btn.classList.add('btn-danger', 'text-white');
            icon.style.color = 'white';
            icon.classList.add('like-animate');
        } else {
            btn.classList.remove('btn-danger', 'text-white');
            btn.classList.add('btn-outline-danger');
            icon.style.color = '#dc3545';
            icon.classList.remove('like-animate');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Please try again later!');
    });
}

// Delete Functions
function confirmDeletePost(postId) {
    if (confirm('Are you sure you want to delete this post? This action cannot be undone!')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/community/post/${postId}/delete`;
        document.body.appendChild(form);
        form.submit();
    }
}

function confirmDeleteComment(commentId) {
    if (confirm('Are you sure you want to delete this comment? This action cannot be undone!')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/community/comment/${commentId}/delete`;
        document.body.appendChild(form);
        form.submit();
    }
}

function confirmDeleteReply(replyId) {
    if (confirm('Are you sure you want to delete this reply? This action cannot be undone!')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/community/reply/${replyId}/delete`;
        document.body.appendChild(form);
        form.submit();
    }
}

// Reply Functions
function showReplyForm(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'block';
}

function hideReplyForm(commentId) {
    document.getElementById(`reply-form-${commentId}`).style.display = 'none';
}

function toggleReplies(commentId) {
    const list = document.getElementById(`reply-list-${commentId}`);
    list.style.display = (list.style.display === 'none') ? 'block' : 'none';
}
</script>
{% endblock %}